{
  "name": "client",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\"",
    "format:fix": "prettier --write \"app/**/*.{ts,tsx}\"",
    "lint:check": "eslint \"app/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"app/**/*.{ts,tsx}\" --fix",
